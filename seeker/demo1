<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Professional Dark Footer - Tailwind CSS</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body class="bg-[#0f172a]">

<footer class="bg-gradient-to-br from-[#0b1020] to-[#111827] text-gray-200 py-16 px-8 md:px-20 animate-fadeUp">

  <!-- TOP SECTION -->
  <div class="grid md:grid-cols-[1.5fr_1fr_1fr] gap-12 md:gap-12 pb-10 text-center md:text-left">

    <!-- LOGO + SOCIAL -->
    <div class="flex flex-col items-center md:items-start">
      <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/7/7c/Naukri_Logo.png/320px-Naukri_Logo.png" alt="Logo" class="w-32 mb-6 brightness-110">

      <div class="text-yellow-400 font-semibold mb-4 text-lg">Connect with us</div>
      <div class="flex gap-5">
        <i class="fa-brands fa-facebook text-gray-400 text-2xl hover:text-yellow-400 transform hover:-translate-y-1 hover:scale-110 transition-all cursor-pointer"></i>
        <i class="fa-brands fa-instagram text-gray-400 text-2xl hover:text-yellow-400 transform hover:-translate-y-1 hover:scale-110 transition-all cursor-pointer"></i>
        <i class="fa-brands fa-x-twitter text-gray-400 text-2xl hover:text-yellow-400 transform hover:-translate-y-1 hover:scale-110 transition-all cursor-pointer"></i>
        <i class="fa-brands fa-linkedin text-gray-400 text-2xl hover:text-yellow-400 transform hover:-translate-y-1 hover:scale-110 transition-all cursor-pointer"></i>
      </div>
    </div>

    <!-- LINKS COLUMN 1 -->
    <div class="flex flex-col justify-center">
      <ul class="space-y-3">
        <li><a href="#" class="text-gray-300 hover:text-yellow-400 transition-colors">Home</a></li>
        <li><a href="#" class="text-gray-300 hover:text-yellow-400 transition-colors">About Us</a></li>
        <li><a href="#" class="text-gray-300 hover:text-yellow-400 transition-colors">Technologies</a></li>
        <li><a href="#" class="text-gray-300 hover:text-yellow-400 transition-colors">Contact Us</a></li>
      </ul>
    </div>

    <!-- LINKS COLUMN 2 -->
    <div class="flex flex-col justify-center">
      <ul class="space-y-3">
        <li><a href="#" class="text-gray-300 hover:text-yellow-400 transition-colors">Privacy Policy</a></li>
        <li><a href="#" class="text-gray-300 hover:text-yellow-400 transition-colors">Terms & Conditions</a></li>
        <li><a href="#" class="text-gray-300 hover:text-yellow-400 transition-colors">Fraud Alert</a></li>
      </ul>
    </div>

  </div>

  <!-- DIVIDER -->
  <div class="border-t border-white/10 mb-4"></div>

  <!-- BOTTOM SECTION -->
  <div class="text-center text-gray-400 text-sm leading-7">
    Designed and developed by CareerCraft Team.<br>
    &copy; 2026 <strong class="text-yellow-400">Rabbitcode</strong>. All rights reserved.
  </div>

</footer>

<!-- ANIMATION -->
<style>
@keyframes fadeUp {
  from {opacity: 0; transform: translateY(40px);}
  to {opacity: 1; transform: translateY(0);}
}
.animate-fadeUp {
  animation: fadeUp 1s ease-in-out;
}
</style>

</body>
</html>
